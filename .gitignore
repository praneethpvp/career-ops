# Personal data lives in praneethpvp/career-ops-data (private repo).
# setup-symlinks.sh in that repo symlinks these paths locally.
# Git ignores them here so personal data never enters this public fork.
_profile.md
cv.md
portals.yml
config/profile.yml
modes/_profile.md
data/applications.md
reports
output
interview-prep
batch/tracker-additions/merged

# Ephemeral runtime data (session-scoped, don't commit)
data/pipeline.md
data/scan-history.tsv
data/*.pdf
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep

# JDs are user-pasted scratch, stay local
jds/*
!jds/.gitkeep

# Update state
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json